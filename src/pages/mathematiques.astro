---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';

const chapters = [
  {
    num: "1",
    title: "Nombres et calculs",
    content: [
      {
        type: "text",
        heading: "Priorités opératoires",
        body: "Les calculs se font dans cet ordre : parenthèses, puissances, multiplications/divisions (de gauche à droite), additions/soustractions (de gauche à droite).",
      },
      {
        type: "formula",
        lines: [
          "Distributivité : a(b + c) = ab + ac",
          "Identité remarquable : (a+b)² = a² + 2ab + b²",
          "Identité remarquable : (a−b)² = a² − 2ab + b²",
          "Différence de carrés : (a+b)(a−b) = a² − b²",
        ],
      },
      { type: "callout", variant: "tip", title: "Astuce exam", body: "Factorise toujours avant de développer : cela simplifie le calcul et évite les erreurs." },
    ],
  },
  {
    num: "2",
    title: "Géométrie",
    content: [
      {
        type: "text",
        heading: "Théorème de Pythagore",
        body: "Dans un triangle rectangle, le carré de l'hypoténuse est égal à la somme des carrés des deux autres côtés.",
      },
      {
        type: "formula",
        lines: [
          "Pythagore : a² + b² = c² (c = hypoténuse)",
          "Réciproque : si a²+b²=c² alors le triangle est rectangle",
          "Aire triangle = (base × hauteur) / 2",
          "Aire disque = π × r²   |   Périmètre = 2πr",
        ],
      },
      {
        type: "text",
        heading: "Théorème de Thalès",
        body: "Si deux droites parallèles coupent deux sécantes passant par un même point, les rapports des longueurs correspondantes sont égaux.",
      },
      {
        type: "formula",
        lines: [
          "Thalès : SA/SB = SC/SD = AC/BD",
          "Volume sphère = (4/3)πr³",
          "Volume cylindre = π × r² × h",
          "Volume cône = (1/3)π × r² × h",
        ],
      },
      { type: "callout", variant: "warn", title: "Erreur fréquente", body: "Vérifier que les droites sont bien parallèles avant d'appliquer Thalès. Toujours écrire la configuration complète." },
    ],
  },
  {
    num: "3",
    title: "Fonctions linéaires et affines",
    content: [
      {
        type: "text",
        heading: "Définitions",
        body: "Une fonction affine est de la forme f(x) = ax + b. Si b = 0, c'est une fonction linéaire. a est le coefficient directeur (pente), b l'ordonnée à l'origine.",
      },
      {
        type: "formula",
        lines: [
          "Fonction affine : f(x) = ax + b",
          "Coefficient directeur : a = (yB − yA) / (xB − xA)",
          "Zéro de la fonction : ax + b = 0  ⟹  x = −b/a",
          "Taux de variation : (f(b) − f(a)) / (b − a)",
        ],
      },
      { type: "callout", variant: "info", title: "Au brevet", body: "On peut te demander de lire graphiquement l'image d'un antécédent ou d'exprimer une équation depuis un graphique." },
    ],
  },
  {
    num: "4",
    title: "Probabilités et statistiques",
    content: [
      {
        type: "text",
        heading: "Probabilités",
        body: "La probabilité d'un événement est comprise entre 0 et 1. La somme des probabilités de tous les événements élémentaires vaut 1.",
      },
      {
        type: "formula",
        lines: [
          "P(A) = nombre de cas favorables / nombre de cas possibles",
          "P(A̅) = 1 − P(A)  (événement contraire)",
          "Moyenne : x̄ = (Σ xi × ni) / Σni",
          "Médiane : valeur qui partage la série en deux parts égales",
        ],
      },
      {
        type: "text",
        heading: "Diagrammes et tableaux",
        body: "Savoir lire un tableau de fréquences, construire un diagramme en barres ou circulaire, et calculer effectif cumulé croissant.",
      },
      { type: "callout", variant: "exam", title: "Point clé exam", body: "Bien distinguer fréquence (entre 0 et 1) et effectif (valeur entière). Vérifier que la somme des fréquences = 1." },
    ],
  },
  {
    num: "5",
    title: "Équations et inéquations",
    content: [
      {
        type: "text",
        heading: "Résolution d'équations",
        body: "Pour résoudre ax + b = cx + d : regrouper les termes en x d'un côté et les constantes de l'autre. Toujours vérifier la solution.",
      },
      {
        type: "formula",
        lines: [
          "Équation du 1er degré : ax + b = 0  ⟹  x = −b/a",
          "Équation du 2e degré : ax² + bx + c = 0",
          "Discriminant : Δ = b² − 4ac",
          "Si Δ > 0 : x = (−b ± √Δ) / 2a",
        ],
      },
      { type: "callout", variant: "tip", title: "Méthode", body: "Pour les inéquations, attention : si tu multiplies/divises par un nombre négatif, le sens de l'inégalité s'inverse." },
    ],
  },
];

const slug = s => s.normalize('NFD').replace(/\p{Diacritic}/gu, '').replace(/[^\w\s-]/g, '').trim().replace(/\s+/g, '-').toLowerCase();

const mathSidebarLinks = [ { title: 'Mathématiques', items: chapters.map(ch => ({ href: `#${slug(ch.title)}`, label: ch.title })) } ];
const videos = [
  { id: 'VIDEO_ID_1', title: 'Priorités opératoires — explication rapide', caption: 'Vidéo courte sur les priorités opératoires et exemples.' },
  { id: 'VIDEO_ID_2', title: 'Théorème de Pythagore — démonstration', caption: 'Démonstration et exercices guidés.' },
  { id: 'VIDEO_ID_3', title: 'Fonctions affines — représentations graphiques', caption: 'Interprétation graphique et exercices.' },
];
---

  <Layout title="Mathématiques" sidebarLinks={mathSidebarLinks}>
  <div class="subject-hero" style="background: linear-gradient(135deg, #ede9fe, #f5f3ff);">
    <div class="subject-hero-inner">
      <div>
        <h1 style="color:var(--color-math);">Mathématiques</h1>
        <p>Révise les chapitres essentiels : calcul, géométrie, fonctions, probabilités et équations. Formules, méthodes et points clés pour l'examen.</p>
      </div>
    </div>
  </div>

  <div class="page-container">
    <div class="callout callout-info" style="margin-bottom:32px;">
      <div class="callout-icon"><Icon name="clipboard" size={18} /></div>
      <div class="callout-body">
        <strong>Format de l'épreuve</strong>
        L'épreuve de mathématiques dure <strong>2h</strong>. Elle comporte plusieurs exercices indépendants. La calculatrice est autorisée sauf mention contraire.
      </div>
    </div>

    <section class="videos-section" style="margin:28px 0;">
      <h2 class="section-title">Vidéos explicatives</h2>
      <p class="section-subtitle">Des vidéos sélectionnées pour consolider les notions clés.</p>
      <div class="cards-grid">
        {videos.map(v => (
          <div class="subject-card">
            <YouTubeEmbed id={v.id} title={v.title} caption={v.caption} />
          </div>
        ))}
      </div>
    </section>

    <div class="chapters">
      {chapters.map(ch => (
        <div class="chapter-card" id={slug(ch.title)}>
          <div class="chapter-header">
            <div class="chapter-num" style="background:var(--color-math-light);color:var(--color-math);">{ch.num}</div>
            <div class="chapter-title">{ch.title}</div>
          </div>
          <div class="chapter-body">
            {ch.content.map(block => (
              <div class="notion-block">
                {block.type === "text" && (
                  <>
                    <h3><span class="notion-bullet"><Icon name="dot" size={12} /></span> {block.heading}</h3>
                    <p>{block.body}</p>
                  </>
                )}
                {block.type === "formula" && (
                  <div class="formula-box">
                    {block.lines?.map(l => <div>{l}</div>)}
                  </div>
                )}
                {block.type === "callout" && (
                  <div class={`callout callout-${block.variant}`}>
                    <div class="callout-icon">
                      {block.variant === "tip" ? <Icon name="check" size={18} /> : block.variant === "warn" ? <Icon name="warn" size={18} /> : block.variant === "info" ? <Icon name="info" size={18} /> : <Icon name="target" size={18} />}
                    </div>
                    <div class="callout-body">
                      <strong>{block.title}</strong>
                      {block.body}
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
