---
export interface Props {
  name: string;
  size?: number;
  class?: string;
}
const { name, size = 20, class: cls = '' } = Astro.props;
---

{/* Simple SVG icon set */}
{name === 'math' && (
<svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
  <path d="M6 12h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M12 6v12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M7 7l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
  <path d="M17 7l-4 4 4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
</svg>
)}

{name === 'book' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M3 5.5A2.5 2.5 0 015.5 3H20v15.5A2.5 2.5 0 0117.5 21H6a3 3 0 01-3-3V5.5z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M8 7h8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
  </svg>
)}

{name === 'globe' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
  <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.75"/>
  <path d="M3 12h18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M12 3c3 3 3 15 0 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M12 3c-3 3-3 15 0 18" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
</svg>
)}

{name === 'microscope' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls}>
  <path d="M8 18h8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M10 6l5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M14 5l2 2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
  <path d="M7 18a5 5 0 0 1 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
</svg>
)}

{name === 'folder' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M3 7a2 2 0 012-2h4l2 2h6a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{name === 'light' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M12 3v1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M12 20v1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M5.2 5.2l.7.7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M18.1 18.1l.7.7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M4 12h1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M19 12h1" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M7 17l3 2 3-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{name === 'clipboard' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M9 2h6v2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="4" y="6" width="16" height="14" rx="2" stroke="currentColor" stroke-width="1.2"/>
    <path d="M8 10h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'check' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
)}

{name === 'warn' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M12 9v4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M12 17h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M10.29 3.86l-7.5 13A2 2 0 004 20h16a2 2 0 001.71-3.14l-7.5-13a2 2 0 00-3.92 0z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
  </svg>
)}

{name === 'info' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.2"/>
    <path d="M12 10h.01M11 16h2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
  </svg>
)}

{name === 'target' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <circle cx="12" cy="12" r="7" stroke="currentColor" stroke-width="1.2"/>
    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.2"/>
    <path d="M21 12h-2M5 12H3M12 3v2M12 19v2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'calendar' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.2"/>
    <path d="M16 3v4M8 3v4M3 11h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'edit' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M4 21v-3l11-11 3 3L7 21H4z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M14 7l3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'brain' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M12 3C8.7 3 6 5 6 8v1H5a3 3 0 00-3 3v2a3 3 0 003 3h14a3 3 0 003-3v-2a3 3 0 00-3-3h-1V8c0-3-2.7-5-6-5z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
  </svg>
)}

{name === 'mic' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <rect x="9" y="2" width="6" height="11" rx="3" stroke="currentColor" stroke-width="1.4"/>
    <path d="M12 15v4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M8 21h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
  </svg>
)}

{name === 'flag' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <path d="M4 21V4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
    <path d="M4 6c4-2 8 0 11 0s7-2 7-2v12c-4 2-8 0-11 0s-7 2-7 2" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
  </svg>
)}

{name === 'dot' && (
  <svg width={size} height={size} viewBox="0 0 24 24" class={cls} xmlns="http://www.w3.org/2000/svg" aria-hidden>
    <circle cx="12" cy="12" r="3" fill="currentColor" />
  </svg>
)}
