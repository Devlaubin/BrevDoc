---
export interface Props {
  title: string;
  description?: string;
  sidebarLinks?: any[];
}
const { title, description = "Prépare ton Brevet avec des cours, fiches et méthodes." } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/mathematiques", label: "Mathématiques" },
  { href: "/francais", label: "Français" },
  { href: "/histoire-geo", label: "Histoire-Géo" },
  { href: "/sciences", label: "Sciences" },
  { href: "/methodologie", label: "Méthodologie" },
];

import Sidebar from "../components/Sidebar.astro";

const defaultSidebarLinks = [
  { title: null, items: [ { href: '/', label: 'Accueil' } ] },
  { title: 'Sujets', items: [
    { href: '/mathematiques', label: 'Mathématiques' },
    { href: '/francais', label: 'Français' },
    { href: '/histoire-geo', label: 'Histoire-Géo' },
    { href: '/sciences', label: 'Sciences' },
    { href: '/methodologie', label: 'Méthodologie' }
  ] }
];

const passedSidebarLinks = Astro.props.sidebarLinks;
const sidebarLinks = passedSidebarLinks ?? defaultSidebarLinks;
const hasSidebar = Boolean(passedSidebarLinks);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} — BrevDoc</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo">
          <span>BrevDoc</span>
        </a>
        <button id="sidebarToggle" class="sidebar-toggle" aria-label="Afficher la navigation">
          ☰
        </button>
        <button class="nav-toggle" aria-label="Menu" id="navToggle">
          <span></span><span></span><span></span>
        </button>
        <nav class="main-nav" id="mainNav">
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={["nav-link", { active: pathname === link.href }]}
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <div class:list={["page-container", { "page-layout": hasSidebar }] }>
        {hasSidebar ? (
          <div class="sidebar-wrapper">
            <Sidebar links={sidebarLinks} />
          </div>
        ) : null}
        <div class="content">
          <slot />
        </div>
      </div>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-brand">BrevDoc — Préparation au Diplôme National du Brevet</p>
        <p class="footer-note">Contenu pédagogique pour les élèves de 3e · Tous niveaux</p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('navToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        nav?.classList.toggle('open');
        toggle.classList.toggle('open');
      });
      const sidebarToggle = document.getElementById('sidebarToggle');
      sidebarToggle?.addEventListener('click', () => {
        document.documentElement.classList.toggle('sidebar-open');
      });

      // Close sidebar when clicking a link on mobile
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (document.documentElement.classList.contains('sidebar-open') && target instanceof HTMLAnchorElement) {
          // if link is inside sidebar, close
          if (target.closest('.doc-sidebar')) {
            document.documentElement.classList.remove('sidebar-open');
          }
        }
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-bg: #F7E7CE;
    --color-surface: #ffffff;
    --color-border: #e9d8c3;
    --color-text: #6B3E2E;
    --color-text-muted: #8b6b5a;
    --color-primary: #C65D3B;
    --color-primary-light: #E07A5F;
    --color-primary-dark: #6B3E2E;
    --color-secondary: #E07A5F;
    --color-secondary-light: #F2CC8F;
    --color-accent: #F2CC8F;
    --color-accent-light: #F7E7CE;
    --color-success: #059669;
    --color-success-light: #d1fae5;
    --color-warning: #d97706;
    --color-warning-light: #fef3c7;
    --color-error: #dc2626;
    --color-error-light: #fee2e2;

    --color-math: #7c3aed;
    --color-math-light: #ede9fe;
    --color-fr: #0891b2;
    --color-fr-light: #cffafe;
    --color-hg: #15803d;
    --color-hg-light: #dcfce7;
    --color-sci: #ea580c;
    --color-sci-light: #ffedd5;
    --color-meth: #be185d;
    --color-meth-light: #fce7f3;

    --font-body: 'Inter', system-ui, sans-serif;
    --font-heading: 'Sora', system-ui, sans-serif;
    --radius: 12px;
    --radius-sm: 6px;
    --shadow-sm: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-md: 0 4px 12px rgba(0,0,0,.08), 0 2px 4px rgba(0,0,0,.04);
    --shadow-lg: 0 12px 32px rgba(0,0,0,.10), 0 4px 8px rgba(0,0,0,.06);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    font-size: 16px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main { flex: 1; }

  a { color: inherit; text-decoration: none; }

  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    line-height: 1.2;
  }

  img { display: block; max-width: 100%; }

  /* ---- Header ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-radius:0 0 15px 15px;
    margin-left: 10px;
    margin-right: 10px;
    border: 1px solid var(--color-border);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-primary);
    flex-shrink: 0;
    transition: opacity .2s;
  }
  .logo:hover { opacity: .8; }

  .logo-icon {
    width: 34px;
    height: 34px;
    background: var(--color-primary);
    color: white;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 800;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
  }

  .nav-link {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    font-size: .9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: background .18s, color .18s;
    white-space: nowrap;
  }
  .nav-link:hover { background: var(--color-primary-light); color: var(--color-primary-dark); }
  .nav-link.active { background: var(--color-primary-light); color: var(--color-secondary-light); font-weight: 600; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }
  .sidebar-toggle {
    display: none;
    margin-left: 8px;
    background: none;
    border: none;
    font-size: 1.05rem;
    cursor: pointer;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform .25s, opacity .25s;
  }
  .nav-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle.open span:nth-child(2) { opacity: 0; }
  .nav-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- Footer ---- */
  .site-footer {
    background: var(--color-text);
    color: #cbd5e1;
    padding: 40px 24px;
    margin-top: 80px;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .footer-brand { color: white; font-weight: 600; font-size: .95rem; }
  .footer-note { font-size: .85rem; }

  /* ---- Page container ---- */
  .page-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  /* Layout with left sidebar */
  .page-layout {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 24px;
    align-items: start;
  }
  .sidebar-wrapper { position: sticky; top: 86px; align-self: start; }
  .content { min-height: 60vh; }

  /* On small screens, collapse to single column so content takes full width
     unless the sidebar is explicitly opened via `html.sidebar-open`. */
  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
    html.sidebar-open .page-container.page-layout { grid-template-columns: 280px 1fr; }
    html.sidebar-open .sidebar-wrapper { display: block; }
    /* Ensure sidebar wrapper doesn't reserve space when closed */
    .sidebar-wrapper { display: none; }
  }

  /* ---- Hero ---- */
  /*.hero {
    color: white;
    padding: 300px 140px;
    text-align: center;
    background-image: linear-gradient(180deg, rgba(0,0,0,0.22), rgba(0,0,0,0.36)), url('/src/assets/back.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }*/
  .hero {
    color: white;
    /* Réduit le padding sur desktop pour remonter le texte d'accueil */
    padding: 140px 80px;
    text-align: center;
    background-color: var(--color-primary) transparent;
  }
  .hero-inner { max-width: 720px; margin: 0 auto; }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.25);
    padding: 4px 14px;
    border-radius: 999px;
    font-size: .8rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    margin-bottom: 16px;
    color: var(--color-text);
  }
  .hero p {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: .88;
    margin-bottom: 32px;
    color: var(--color-text);
  }
  .hero-actions { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: .95rem;
    transition: transform .18s, box-shadow .18s, background .18s;
    cursor: pointer;
    border: none;
  }
  .btn:hover { transform: scale(1.05); box-shadow: 0 6px 20px rgba(0,0,0,.2); }
  .btn-primary { background: white; color: var(--color-primary); }
  .btn-outline { background: transparent; color: var(--color-text); border: 2px solid rgba(255, 255, 255, 0.6); }
  .btn-outline:hover { background: rgba(255, 255, 255, 0.6); color: var(--color-secondary-light); }

  /* ---- Section title ---- */
  .section-title {
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 8px;
  }
  .section-subtitle {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin-bottom: 40px;
  }

  /* ---- Cards grid ---- */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .subject-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: transform .22s, box-shadow .22s;
    box-shadow: var(--shadow-sm);
    cursor: pointer;
  }
  .subject-card:hover { border-color: 2px solid var(--color-primary);transform: scale(0.95)}

  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }
  .card-title { font-size: 1.1rem; font-weight: 700; }
  .card-desc { font-size: .9rem; color: var(--color-text-muted); line-height: 1.6; flex: 1; }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: .9rem;
    font-weight: 600;
    margin-top: 4px;
    transition: gap .18s;
  }
  .card-link:hover { gap: 10px; text-decoration: underline; }

  /* ---- Subject page header ---- */
  .subject-hero {
    position: relative;
    padding: 56px 24px 48px;
    margin-bottom: 0;
    display: flex;
    justify-content: center;
    border-radius: var(--radius);
    margin: 20px 10px;
  }
  .subject-hero-inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 24px; text-align: center; }
  .subject-hero-icon {
    width: 64px;
    height: 64px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
    margin-top: 4px;
  }
  .subject-hero h1 { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; margin-bottom: 8px; }
  .subject-hero p { font-size: 1rem; color: var(--color-text-muted); max-width: 600px; line-height: 1.7; }

  /* ---- Chapters ---- */
  .chapters { display: flex; flex-direction: column; gap: 32px; }

  .chapter-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .chapter-header {
    padding: 20px 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    border-bottom: 1px solid var(--color-border);
  }
  .chapter-num {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: .9rem;
    flex-shrink: 0;
  }
  .chapter-title { font-size: 1.1rem; font-weight: 700; }
  .chapter-body { padding: 24px 28px; }

  .notion-block {
    margin-bottom: 20px;
  }
  .notion-block:last-child { margin-bottom: 0; }

  .notion-block h3 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .notion-block p, .notion-block li {
    font-size: .93rem;
    line-height: 1.75;
    color: #374151;
  }
  .notion-block ul, .notion-block ol {
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .callout {
    border-radius: 8px;
    padding: 14px 18px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-top: 16px;
  }
  .callout-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 1px; }
  .callout-body { font-size: .91rem; line-height: 1.7; }
  .callout-body strong { font-weight: 700; display: block; margin-bottom: 2px; }

  .callout-tip { background: var(--color-success-light); color: #065f46; }
  .callout-warn { background: var(--color-warning-light); color: #78350f; }
  .callout-info { background: var(--color-primary-light); color: #ecb94a; }
  .callout-exam { background: var(--color-error-light); color: #991b1b; }

  .formula-box {
    background: #f1f5f9;
    border-left: 4px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
    padding: 14px 18px;
    font-family: 'Courier New', monospace;
    font-size: .9rem;
    margin-top: 10px;
    line-height: 1.8;
    color: var(--color-text);
  }

  .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
  .subject-hero .tags {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  .tag {
    padding: 3px 10px;
    border-radius: 999px;
    font-size: .78rem;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
  }

  /* ---- Progress banner ---- */
  .progress-banner {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-secondary-light));
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 24px 28px;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .progress-text { flex: 1; min-width: 200px; }
  .progress-text strong { display: block; font-weight: 700; margin-bottom: 4px; }
  .progress-text span { font-size: .9rem; color: var(--color-text-muted); }

  /* ---- Stat cards ---- */
  .stats-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }
  .stat-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: transform .18s, box-shadow .18s;
  }
  .stat-value { font-size: 2rem; font-weight: 800; font-family: var(--font-heading); }
  .stat-label { font-size: .82rem; color: var(--color-text-muted); margin-top: 4px; }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .sidebar-toggle { display: block; }
    .main-nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: white;
      border-bottom: 1px solid var(--color-border);
      flex-direction: column;
      padding: 12px 16px;
      gap: 4px;
      box-shadow: var(--shadow-md);
      z-index: 100;
      border-radius: var(--radius);
    }
    .main-nav.open { display: flex; }
    .nav-link { padding: 10px 14px; width: 100%; }

    .header-inner { position: relative; }

    .subject-hero-inner { flex-direction: column; gap: 16px; }
    .chapter-header { flex-wrap: wrap; }
    .chapter-body { padding: 20px; }
    .hero { padding: 56px 20px; }
    .stats-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>
